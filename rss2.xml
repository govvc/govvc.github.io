    <item>
      <title>java中Collections.sort排序详解</title>
      <link>http://example.com/2021/04/11/java%E4%B8%ADCollections.sort%E6%8E%92%E5%BA%8F%E8%AF%A6%E8%A7%A3/</link>
      <guid>http://example.com/2021/04/11/java%E4%B8%ADCollections.sort%E6%8E%92%E5%BA%8F%E8%AF%A6%E8%A7%A3/</guid>
